# Force LF for every text file, on commit and on checkout — regardless of the
# contributor's core.autocrlf. The dev stack runs under WSL (LF), so Windows
# checkouts must not introduce CRLF. This is the prevention layer; core.autocrlf
# should also be set to false locally.
* text=auto eol=lf

# Windows-only scripts must keep CRLF to stay runnable from cmd.exe.
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary assets — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   text eol=lf
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.jar   binary
*.zip   binary
*.gz    binary
*.keystore binary
