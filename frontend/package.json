{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve web",
    "build": "ng build web",
    "watch": "ng build web --watch --configuration development",
    "test": "ng test web",
    "test:coverage": "ng test web --configuration=coverage",
    "lint": "ng lint web && ng lint ui",
    "format": "prettier --write \"{apps,libs}/**/*.{ts,html,scss}\"",
    "ui:build": "ng build ui",
    "ui:test": "ng test ui",
    "ui:lint": "ng lint ui",
    "storybook": "ng run ui:storybook",
    "storybook:build": "ng run ui:build-storybook"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "@angular/animations": "^21.2.16",
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.16",
    "@angular/compiler": "^21.2.16",
    "@angular/core": "^21.2.16",
    "@angular/forms": "^21.2.16",
    "@angular/material": "^21.2.14",
    "@angular/platform-browser": "^21.2.16",
    "@angular/router": "^21.2.16",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@sentry/browser": "^8.55.0",
    "material-icons": "^1.0.0",
    "rxjs": "^7.0.0",
    "tslib": "^2.0.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.14",
    "@angular/cli": "^21.2.14",
    "@angular/compiler-cli": "^21.2.16",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/angular": "^10.3.6",
    "@vitest/coverage-v8": "^4.1.8",
    "angular-eslint": "21.4.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.3",
    "prettier": "^3.0.0",
    "storybook": "^10.3.6",
    "typescript": "~5.9.0",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.0.0"
  }
}
