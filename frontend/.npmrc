# Storybook 10.x peer-dep compat shim — required while Storybook hasn't shipped a release
# that supports Angular 22. The conflict :
#
#   @storybook/angular@10.4.2 → peer @angular-devkit/build-angular @">=18.0.0 < 22.0.0"
#                            → peer @angular/core              @">=18.0.0 < 22.0.0"
#
# Our workspace pins @angular/core@22 + @angular/build (Angular 22 dropped the legacy
# @angular-devkit/build-angular bundle). To keep Storybook usable in the meantime, we install
# `@angular-devkit/build-angular@21.2.14` as a side-dep (devDeps) and accept the peer-dep
# warning via this config. Same effect as passing `--legacy-peer-deps` on every command, but
# also picked up by `npm ci` in CI — no workflow tweak needed.
#
# **Remove this file when Storybook ships a release that supports Angular 22 natively** (and
# bump @storybook/angular + drop the @angular-devkit/build-angular pin from devDeps).
legacy-peer-deps=true
