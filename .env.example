# ────────────────────────────────────────────────────────────────────────
# Port mapping pour la stack locale (PortfolioAI)
# ────────────────────────────────────────────────────────────────────────
#
# Copie ce fichier en `.env` à la racine du repo et édite uniquement les
# valeurs qui te posent problème (un `tilt up` qui échoue sur « port already
# allocated » indique précisément lequel). Le `.env` est gitignored — tes
# ports locaux ne sortent pas du repo.
#
# Toutes les valeurs ci-dessous sont les défauts ; si une variable n'est pas
# définie, le `docker-compose.yml`, le `Tiltfile` et `application.yml`
# retombent sur ces valeurs. Tu n'es donc pas obligé de copier ce fichier
# tant que les défauts marchent chez toi.
#
# Cas le plus courant : un Postgres déjà installé localement occupe 5432.
# Mets `POSTGRES_HOST_PORT=5433` (ou autre libre) dans ton `.env`.

# Postgres — port exposé sur l'hôte (le container reste en 5432 en interne).
# Le backend Spring se connecte sur ce port via `application.yml`.
POSTGRES_HOST_PORT=5432

# Ollama — port exposé sur l'hôte (le container reste en 11434 en interne).
# Le backend Spring s'y connecte via `ollama.base-url` dans `application-local.yml`.
OLLAMA_HOST_PORT=11434

# Backend Spring Boot (lancé en natif par Tilt, pas en container).
BACKEND_HOST_PORT=8080

# Frontend Angular (dev server).
FRONTEND_HOST_PORT=4200
